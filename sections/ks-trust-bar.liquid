<section class="thr-trustbar">
  <div class="thr-trustbar-inner">
    <div class="thr-trust-item">
      <span class="thr-trust-icon">🔴</span>
      <span class="thr-trust-text">FDA-Registered<br>Red Light Tech</span>
    </div>
    <div class="thr-trust-item">
      <span class="thr-trust-icon">🛡️</span>
      <span class="thr-trust-text">30-Day Money<br>Back Guarantee</span>
    </div>
    <div class="thr-trust-item">
      <span class="thr-trust-icon">🚚</span>
      <span class="thr-trust-text">Free Shipping<br>Over $50</span>
    </div>
    <div class="thr-trust-item">
      <span class="thr-trust-icon">⭐</span>
      <span class="thr-trust-text">4.4/5 From<br>500+ Customers</span>
    </div>
  </div>
</section>

<style>
.thr-trustbar {
  background: #F7F7F7;
  padding: 32px 24px;
}
.thr-trustbar-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.thr-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 8px;
}
.thr-trust-icon { font-size: 26px; }
.thr-trust-text {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
}

@media (max-width: 768px) {
  .thr-trustbar-inner { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .thr-trust-icon { font-size: 22px; }
  .thr-trust-text { font-size: 11px; }
}
</style>

{% schema %}
{
  "name": "Thrivve Trust Bar",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [{ "name": "Thrivve Trust Bar" }]
}
{% endschema %}
