<section class="thr-email-capture">
  <div class="thr-email-inner">
    <h2 class="thr-email-heading">{{ section.settings.heading | default: 'Get 10% Off Your First Order' }}</h2>
    <p class="thr-email-sub">{{ section.settings.subheading | default: 'Sign up for restock alerts, routine tips, and exclusive discounts.' }}</p>

    {% form 'customer' %}
      {% if form.posted_successfully? %}
        <p class="thr-email-success">Thanks — you're on the list!</p>
      {% else %}
        <div class="thr-email-form-row">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="Enter your email address" required class="thr-email-input">
          <button type="submit" class="thr-email-submit">Get My Discount</button>
        </div>
      {% endif %}
    {% endform %}
  </div>
</section>

<style>
.thr-email-capture {
  background: #0B0B0B;
  padding: 56px 32px;
  text-align: center;
}
.thr-email-inner { max-width: 560px; margin: 0 auto; }
.thr-email-heading {
  font-family: 'Inter', sans-serif;
  font-size: 26px;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 10px;
}
.thr-email-sub {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: #BBBBBB;
  margin-bottom: 26px;
}
.thr-email-form-row {
  display: flex;
  gap: 10px;
}
.thr-email-input {
  flex: 1;
  background: #1A1A1A;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  padding: 14px 16px;
  outline: none;
}
.thr-email-input::placeholder { color: #777; }
.thr-email-input:focus { border-color: #E63946; }
.thr-email-submit {
  background: #E63946;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  padding: 14px 22px;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s;
}
.thr-email-submit:hover { background: #c92b38; }
.thr-email-success {
  font-family: 'Inter', sans-serif;
  color: #4CAF50;
  font-size: 14px;
  font-weight: 700;
}

@media (max-width: 600px) {
  .thr-email-capture { padding: 36px 18px; }
  .thr-email-heading { font-size: 20px; }
  .thr-email-form-row { flex-direction: column; }
}
</style>

{% schema %}
{
  "name": "Thrivve Email Capture",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% Off Your First Order" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Sign up for restock alerts, routine tips, and exclusive discounts." }
  ],
  "presets": [{ "name": "Thrivve Email Capture" }]
}
{% endschema %}
