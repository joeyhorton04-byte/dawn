<style>
  .thrivve-photo-testimonials {
    padding: 4rem 0;
  }
  .thrivve-photo-testimonials__heading {
    text-align: center;
    font-size: 3rem;
    margin-bottom: 3.2rem;
  }
  .thrivve-photo-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
  }
  .thrivve-photo-card {
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255,255,255,0.04);
  }
  .thrivve-photo-card__image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    background: #111;
  }
  .thrivve-photo-card__body {
    padding: 2rem;
  }
  .thrivve-photo-card__stars {
    color: #f5a623;
    font-size: 1.6rem;
    margin-bottom: 0.8rem;
  }
  .thrivve-photo-card__title {
    font-size: 1.7rem;
    margin: 0 0 0.8rem;
  }
  .thrivve-photo-card__quote {
    font-size: 1.4rem;
    line-height: 1.6;
    opacity: 0.85;
    margin: 0 0 1.2rem;
  }
  .thrivve-photo-card__author {
    font-size: 1.3rem;
    font-weight: 600;
    opacity: 0.7;
    margin: 0;
  }
  .thrivve-photo-testimonials__note {
    text-align: center;
    font-size: 1.2rem;
    opacity: 0.5;
    margin-top: 2.4rem;
  }
  @media screen and (max-width: 989px) {
    .thrivve-photo-testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="thrivve-photo-testimonials color-{{ section.settings.color_scheme }} page-width">
  {% if section.settings.heading != blank %}
    <h2 class="thrivve-photo-testimonials__heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}

  <div class="thrivve-photo-testimonials__grid">
    {% for block in section.blocks %}
      {% if block.type == 'photo_testimonial' %}
        <div class="thrivve-photo-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: class: 'thrivve-photo-card__image', loading: 'lazy' }}
          {% else %}
            <div class="thrivve-photo-card__image"></div>
          {% endif %}
          <div class="thrivve-photo-card__body">
            <div class="thrivve-photo-card__stars">
              {% for i in (1..5) %}
                {% if i <= block.settings.rating %}★{% else %}☆{% endif %}
              {% endfor %}
            </div>
            {% if block.settings.title != blank %}
              <h3 class="thrivve-photo-card__title">{{ block.settings.title | escape }}</h3>
            {% endif %}
            {% if block.settings.quote != blank %}
              <p class="thrivve-photo-card__quote">"{{ block.settings.quote | escape }}"</p>
            {% endif %}
            {% if block.settings.author != blank %}
              <p class="thrivve-photo-card__author">{{ block.settings.author | escape }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <p class="thrivve-photo-testimonials__note">Replace these placeholder reviews with real, verified customer testimonials before publishing.</p>
</div>

{% schema %}
{
  "name": "Thrivve Photo Testimonials",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Results, Real Customers"
    }
  ],
  "blocks": [
    {
      "type": "photo_testimonial",
      "name": "Photo testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer photo"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Add a real review title here"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Replace with a real customer quote once you have verified reviews."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "First name + last initial"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Photo Testimonials",
      "blocks": [
        { "type": "photo_testimonial" },
        { "type": "photo_testimonial" },
        { "type": "photo_testimonial" }
      ]
    }
  ]
}
{% endschema %}
