<section class="ks-mp">

  <!-- HERO -->
  <div class="ks-mp-hero">
    <div class="ks-mp-cross"></div>
    <div class="ks-mp-hero-content">
      <p class="ks-mp-eyebrow">✝ Our Mission</p>
      <h1 class="ks-mp-title">Not Just Jewelry —<br><span class="ks-mp-gold">The Good News</span></h1>
      <p class="ks-mp-verse">"Go and make disciples of all nations..."</p>
      <p class="ks-mp-verse-ref">Matthew 28:19</p>
    </div>
  </div>

  <!-- MISSION STATEMENT -->
  <div class="ks-mp-section">
    <div class="ks-mp-divider">
      <div class="ks-mp-line"></div>
      <span class="ks-mp-cross-icon">✝</span>
      <div class="ks-mp-line ks-mp-line-right"></div>
    </div>
    <h2 class="ks-mp-heading">Why We Exist</h2>
    <p class="ks-mp-body">Kingdom Supply was built on one belief — that faith should be worn boldly. Every piece we create is designed to spark conversation, remind believers of who they live for, and spread the Gospel without saying a word.</p>
    <p class="ks-mp-body">We are not just a jewelry brand. We are a ministry wrapped in steel and gold — crafting pieces that carry meaning, purpose, and the message of Christ into every room, every gym, every conversation.</p>
  </div>

  <!-- THREE PILLARS -->
  <div class="ks-mp-pillars">
    <div class="ks-mp-pillar">
      <div class="ks-mp-pillar-icon">✝</div>
      <h3 class="ks-mp-pillar-title">Faith First</h3>
      <p class="ks-mp-pillar-body">Every design starts with scripture. We create pieces that are rooted in the Word and crafted to carry His message wherever you go.</p>
    </div>
    <div class="ks-mp-pillar">
      <div class="ks-mp-pillar-icon">⚡</div>
      <h3 class="ks-mp-pillar-title">Built to Last</h3>
      <p class="ks-mp-pillar-body">Premium 316L stainless steel. Waterproof, tarnish-free, and backed by a lifetime guarantee. Your faith is forever — so is our jewelry.</p>
    </div>
    <div class="ks-mp-pillar">
      <div class="ks-mp-pillar-icon">🙏</div>
      <h3 class="ks-mp-pillar-title">Kingdom Impact</h3>
      <p class="ks-mp-pillar-body">10% of every sale goes directly to local ministry and church outreach. Your purchase spreads the Gospel and supports communities in need.</p>
    </div>
  </div>

  <!-- DONATE SECTION -->
  <div class="ks-mp-donate">
    <div class="ks-mp-donate-inner">
      <p class="ks-mp-donate-eyebrow">✝ Your Purchase Makes An Impact</p>
      <h2 class="ks-mp-donate-title">10% of Every Sale Goes to Ministry</h2>
      <p class="ks-mp-donate-body">Every order you place directly funds local church outreach and ministry work. You're not just buying jewelry — you're spreading the Gospel and supporting believers around the world.</p>
      <a href="/collections/best-sellers" class="ks-mp-cta">Shop & Make An Impact</a>
    </div>
  </div>

  <!-- VERSE SECTION -->
  <div class="ks-mp-verse-section">
    <div class="ks-mp-verse-inner">
      <p class="ks-mp-big-verse">"For I am not ashamed of the gospel, because it is the power of God that brings salvation to everyone who believes."</p>
      <p class="ks-mp-big-verse-ref">Romans 1:16</p>
    </div>
  </div>

</section>

<style>
.ks-mp { background: #0A0A0A; color: #FAFAF5; }

/* HERO */
.ks-mp-hero {
  min-height: 60vh;
  background: #111111;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  overflow: hidden;
  padding: 80px 24px;
}
.ks-mp-cross {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400px;
  height: 400px;
  opacity: 0.03;
  background: #C9A84C;
  clip-path: polygon(40% 0%, 60% 0%, 60% 35%, 100% 35%, 100% 55%, 60% 55%, 60% 100%, 40% 100%, 40% 55%, 0% 55%, 0% 35%, 40% 35%);
}
.ks-mp-hero-content { position: relative; z-index: 2; max-width: 700px; }
.ks-mp-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 4px;
  color: #C9A84C;
  text-transform: uppercase;
  margin-bottom: 20px;
}
.ks-mp-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(32px, 6vw, 64px);
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 2px;
  line-height: 1.05;
  margin-bottom: 24px;
  color: #FAFAF5;
}
.ks-mp-gold { color: #C9A84C; }
.ks-mp-verse {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 20px;
  color: #C9A84C;
  margin-bottom: 8px;
}
.ks-mp-verse-ref {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  color: #888888;
  text-transform: uppercase;
}

/* MISSION STATEMENT */
.ks-mp-section {
  max-width: 800px;
  margin: 0 auto;
  padding: 80px 24px;
  text-align: center;
}
.ks-mp-divider {
  display: flex;
  align-items: center;
  gap: 16px;
  max-width: 160px;
  margin: 0 auto 40px;
}
.ks-mp-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, transparent, #8B6914);
}
.ks-mp-line-right {
  background: linear-gradient(to left, transparent, #8B6914);
}
.ks-mp-cross-icon { color: #C9A84C; font-size: 16px; }
.ks-mp-heading {
  font-family: 'Cinzel', serif;
  font-size: clamp(24px, 4vw, 40px);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 3px;
  color: #FAFAF5;
  margin-bottom: 28px;
}
.ks-mp-body {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  color: #CCCCCC;
  line-height: 1.8;
  margin-bottom: 20px;
}

/* PILLARS */
.ks-mp-pillars {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: #1A1A1A;
  border-top: 1px solid rgba(201,168,76,0.1);
  border-bottom: 1px solid rgba(201,168,76,0.1);
}
.ks-mp-pillar {
  background: #0A0A0A;
  padding: 48px 32px;
  text-align: center;
  transition: background 0.3s;
}
.ks-mp-pillar:hover { background: #111111; }
.ks-mp-pillar-icon {
  font-size: 32px;
  margin-bottom: 20px;
  display: block;
}
.ks-mp-pillar-title {
  font-family: 'Cinzel', serif;
  font-size: 16px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #C9A84C;
  margin-bottom: 16px;
}
.ks-mp-pillar-body {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  color: #888888;
  line-height: 1.7;
}

/* DONATE */
.ks-mp-donate {
  background: #111111;
  padding: 80px 24px;
  text-align: center;
  border-top: 1px solid rgba(201,168,76,0.1);
}
.ks-mp-donate-inner { max-width: 700px; margin: 0 auto; }
.ks-mp-donate-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 4px;
  color: #C9A84C;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.ks-mp-donate-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(24px, 4vw, 40px);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #FAFAF5;
  margin-bottom: 20px;
  line-height: 1.1;
}
.ks-mp-donate-body {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  color: #CCCCCC;
  line-height: 1.8;
  margin-bottom: 36px;
}
.ks-mp-cta {
  display: inline-block;
  background: #C9A84C;
  color: #0A0A0A;
  padding: 16px 40px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  text-decoration: none;
  transition: background 0.25s;
}
.ks-mp-cta:hover { background: #E8C97A; }

/* VERSE SECTION */
.ks-mp-verse-section {
  padding: 80px 24px;
  background: #0A0A0A;
  text-align: center;
}
.ks-mp-verse-inner { max-width: 700px; margin: 0 auto; }
.ks-mp-big-verse {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(20px, 3vw, 28px);
  font-style: italic;
  color: #C9A84C;
  line-height: 1.6;
  margin-bottom: 16px;
}
.ks-mp-big-verse-ref {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  color: #888888;
  text-transform: uppercase;
}

/* MOBILE */
@media (max-width: 768px) {
  .ks-mp-pillars { grid-template-columns: 1fr; }
  .ks-mp-pillar { padding: 40px 24px; }
  .ks-mp-section { padding: 60px 24px; }
  .ks-mp-donate { padding: 60px 24px; }
  .ks-mp-verse-section { padding: 60px 24px; }
  .ks-mp-cta { width: 100%; text-align: center; display: block; }
}
</style>

