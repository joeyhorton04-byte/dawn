{%- style -%}
  .thrivve-hero-product {
    padding: 4rem 0;
  }
  .thrivve-hero-product__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 5rem;
    align-items: start;
  }
  .thrivve-hero-product__gallery-main {
    border-radius: 8px;
    overflow: hidden;
    background: #111;
    margin-bottom: 1.2rem;
  }
 {{ product.featured_media | image_url: width: 1200 | image_tag: loading: 'lazy', id: 'thrivve-hero-main-image' }}
  .thrivve-hero-product__thumbs {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .thrivve-hero-product__thumb {
    width: 80px;
    height: 80px;
    border-radius: 6px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    background: #111;
    padding: 0;
  }
  .thrivve-hero-product__thumb.is-active {
    border-color: {{ section.settings.accent_color }};
  }
  .thrivve-hero-product__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .thrivve-hero-product__reviews {
    font-size: 1.4rem;
    margin-bottom: 1rem;
    opacity: 0.8;
  }
  .thrivve-hero-product__reviews .stars {
    color: #f5a623;
    margin-right: 0.6rem;
    letter-spacing: 0.1em;
  }
  .thrivve-hero-product__title {
    font-size: 3.4rem;
    line-height: 1.1;
    margin: 0 0 1.4rem;
  }
  .thrivve-hero-product__price-row {
    display: flex;
    align-items: baseline;
    gap: 1.2rem;
    margin-bottom: 1.8rem;
    flex-wrap: wrap;
  }
  .thrivve-hero-product__price {
    font-size: 2.6rem;
    font-weight: 700;
  }
  .thrivve-hero-product__compare-price {
    font-size: 1.8rem;
    text-decoration: line-through;
    opacity: 0.55;
  }
  .thrivve-hero-product__save-badge {
    background: {{ section.settings.accent_color }};
    color: #fff;
    font-size: 1.2rem;
    font-weight: 700;
    padding: 0.3rem 1rem;
    border-radius: 4px;
    letter-spacing: 0.04em;
  }
  .thrivve-hero-product__benefits {
    list-style: none;
    margin: 0 0 2.2rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .thrivve-hero-product__benefits li {
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .thrivve-hero-product__variants {
    margin-bottom: 1.6rem;
  }
  .thrivve-hero-product__variants fieldset {
    border: none;
    padding: 0;
    margin: 0 0 1.2rem;
  }
  .thrivve-hero-product__variants legend {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
    opacity: 0.8;
  }
  .thrivve-hero-product__variants select {
    width: 100%;
    padding: 1.1rem 1.4rem;
    font-size: 1.5rem;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    color: inherit;
  }
  .thrivve-hero-product__quantity {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }
  .thrivve-hero-product__quantity label {
    font-size: 1.3rem;
    font-weight: 600;
    opacity: 0.8;
  }
  .thrivve-hero-product__quantity input {
    width: 70px;
    padding: 0.9rem;
    font-size: 1.5rem;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    color: inherit;
    text-align: center;
  }
  .thrivve-hero-product__buy-button {
    width: 100%;
    padding: 1.6rem;
    font-size: 1.6rem;
    border: none;
    border-radius: 6px;
    background: {{ section.settings.accent_color }};
    color: #fff;
    cursor: pointer;
    font-weight: 700;
  }
  .thrivve-hero-product__buy-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .thrivve-hero-product__guarantee {
    font-size: 1.3rem;
    opacity: 0.7;
    margin-top: 1.4rem;
    text-align: center;
  }
  .thrivve-hero-product__inventory {
    font-size: 1.3rem;
    font-weight: 600;
    color: {{ section.settings.accent_color }};
    text-align: center;
    padding: 1rem 0;
    border-top: 1px solid rgba(255,255,255,0.12);
    border-bottom: 1px solid rgba(255,255,255,0.12);
    margin: 1.6rem 0;
  }

  /* Bundle tiers */
  .thrivve-bundles {
    margin-bottom: 1.6rem;
  }
  .thrivve-bundle-tier {
    border: 2px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    margin-bottom: 1.2rem;
    overflow: hidden;
    position: relative;
  }
  .thrivve-bundle-tier.is-selected {
    border-color: {{ section.settings.accent_color }};
  }
  .thrivve-bundle-tier__badge {
    position: absolute;
    top: -1px;
    right: 1.6rem;
    background: {{ section.settings.accent_color }};
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    padding: 0.4rem 1.2rem;
    border-radius: 0 0 6px 6px;
    letter-spacing: 0.04em;
  }
  .thrivve-bundle-tier__header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.6rem 1.8rem;
    cursor: pointer;
  }
  .thrivve-bundle-tier__radio {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.3);
    flex-shrink: 0;
    position: relative;
  }
  .thrivve-bundle-tier.is-selected .thrivve-bundle-tier__radio {
    border-color: {{ section.settings.accent_color }};
  }
  .thrivve-bundle-tier.is-selected .thrivve-bundle-tier__radio::after {
    content: '';
    position: absolute;
    inset: 3px;
    background: {{ section.settings.accent_color }};
    border-radius: 50%;
  }
  .thrivve-bundle-tier__name {
    flex: 1;
  }
  .thrivve-bundle-tier__name strong {
    display: block;
    font-size: 1.5rem;
  }
  .thrivve-bundle-tier__name span {
    font-size: 1.3rem;
    opacity: 0.65;
  }
  .thrivve-bundle-tier__price {
    text-align: right;
    flex-shrink: 0;
  }
  .thrivve-bundle-tier__price strong {
    display: block;
    font-size: 1.5rem;
  }
  .thrivve-bundle-tier__price del {
    font-size: 1.2rem;
    opacity: 0.5;
  }
  .thrivve-bundle-tier__items {
    display: none;
    padding: 0 1.8rem 1.6rem;
    gap: 1.2rem;
  }
  .thrivve-bundle-tier.is-selected .thrivve-bundle-tier__items {
    display: flex;
  }
  .thrivve-bundle-tier__item {
    flex: 1;
    background: rgba(255,255,255,0.04);
    border-radius: 6px;
    padding: 1.2rem;
    text-align: center;
    font-size: 1.3rem;
  }
  .thrivve-bundle-tier__item img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 4px;
    margin: 0 auto 0.8rem;
    display: block;
  }

  .thrivve-addon {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.6rem;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    margin-bottom: 1rem;
    cursor: pointer;
  }
  .thrivve-addon input {
    width: 18px;
    height: 18px;
    accent-color: {{ section.settings.accent_color }};
  }
  .thrivve-addon__label {
    flex: 1;
    font-size: 1.4rem;
    font-weight: 600;
  }
  .thrivve-addon__price {
    font-size: 1.4rem;
    font-weight: 600;
    opacity: 0.8;
  }
  .thrivve-bundle-disclaimer {
    font-size: 1.1rem;
    opacity: 0.5;
    text-align: center;
    margin-top: 1rem;
  }

  @media screen and (max-width: 749px) {
    .thrivve-hero-product__grid {
      grid-template-columns: 1fr;
      gap: 2.4rem;
    }
    .thrivve-hero-product__title {
      font-size: 2.6rem;
    }
  }
{%- endstyle -%}

{%- assign product = section.settings.product -%}

<div class="thrivve-hero-product color-{{ section.settings.color_scheme }} page-width">
  {%- if product != blank -%}
    <div class="thrivve-hero-product__grid">

      <div class="thrivve-hero-product__gallery">
        <div class="thrivve-hero-product__gallery-main">
          {%- if product.featured_media != blank -%}
            {{ product.featured_media | image_url: width: 1200 | image_tag: loading: 'lazy', id: 'thrivve-hero-main-image' }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="thrivve-hero-product__thumbs">
            {%- for media in product.media limit: 6 -%}
              <button type="button" class="thrivve-hero-product__thumb {% if forloop.first %}is-active{% endif %}" data-full-src="{{ media | image_url: width: 1200 }}">
                {{ media | image_url: width: 160 | image_tag: loading: 'lazy' }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="thrivve-hero-product__info">
        {%- if section.settings.show_reviews -%}
          <p class="thrivve-hero-product__reviews">
            <span class="stars">★★★★★</span>{{ section.settings.review_rating }}/5 ({{ section.settings.review_count }} Reviews)
          </p>
        {%- endif -%}

        <h1 class="thrivve-hero-product__title">{{ product.title }}</h1>

        <div class="thrivve-hero-product__price-row">
          <span class="thrivve-hero-product__price">{{ product.selected_or_first_available_variant.price | money }}</span>
          {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
            <span class="thrivve-hero-product__compare-price">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
            {%- assign discount = product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100.0 | divided_by: product.selected_or_first_available_variant.compare_at_price | round -%}
            <span class="thrivve-hero-product__save-badge">SAVE {{ discount }}%</span>
          {%- endif -%}
        </div>

        {%- if section.settings.benefit_1 != blank or section.settings.benefit_2 != blank or section.settings.benefit_3 != blank -%}
          <ul class="thrivve-hero-product__benefits">
            {%- if section.settings.benefit_1 != blank -%}<li>{{ section.settings.benefit_1 }}</li>{%- endif -%}
            {%- if section.settings.benefit_2 != blank -%}<li>{{ section.settings.benefit_2 }}</li>{%- endif -%}
            {%- if section.settings.benefit_3 != blank -%}<li>{{ section.settings.benefit_3 }}</li>{%- endif -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.show_inventory and product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
          {%- assign qty = product.selected_or_first_available_variant.inventory_quantity -%}
          {%- if qty > 0 and qty <= section.settings.low_stock_threshold -%}
            <p class="thrivve-hero-product__inventory">Only {{ qty }} left in stock!</p>
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.show_bundles -%}
          <div class="thrivve-bundles">
            {%- for block in section.blocks -%}
              {%- if block.type == 'bundle_tier' -%}
                <div class="thrivve-bundle-tier {% if forloop.first %}is-selected{% endif %}" data-bundle-tier data-price="{{ block.settings.price }}" {{ block.shopify_attributes }}>
                  {%- if block.settings.badge != blank -%}
                    <span class="thrivve-bundle-tier__badge">{{ block.settings.badge | escape }}</span>
                  {%- endif -%}
                  <div class="thrivve-bundle-tier__header">
                    <span class="thrivve-bundle-tier__radio"></span>
                    <span class="thrivve-bundle-tier__name">
                      <strong>{{ block.settings.name | escape }}</strong>
                      <span>{{ block.settings.subtitle | escape }}</span>
                    </span>
                    <span class="thrivve-bundle-tier__price">
                      <strong>${{ block.settings.price }}</strong>
                      {%- if block.settings.compare_price != blank -%}<del>${{ block.settings.compare_price }}</del>{%- endif -%}
                    </span>
                  </div>
                  {%- if block.settings.item_1_name != blank or block.settings.item_2_name != blank -%}
                    <div class="thrivve-bundle-tier__items">
                      {%- if block.settings.item_1_name != blank -%}
                        <div class="thrivve-bundle-tier__item">{{ block.settings.item_1_name | escape }}</div>
                      {%- endif -%}
                      {%- if block.settings.item_2_name != blank -%}
                        <div class="thrivve-bundle-tier__item">{{ block.settings.item_2_name | escape }}</div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- for block in section.blocks -%}
            {%- if block.type == 'addon' -%}
              <label class="thrivve-addon" {{ block.shopify_attributes }}>
                <input type="checkbox" data-addon-price="{{ block.settings.price }}" {% if block.settings.checked_by_default %}checked{% endif %}>
                <span class="thrivve-addon__label">{{ block.settings.label | escape }}</span>
                <span class="thrivve-addon__price">+${{ block.settings.price }}</span>
              </label>
            {%- endif -%}
          {%- endfor -%}

          <p class="thrivve-bundle-disclaimer">Placeholder bundle pricing — connect a bundle app to charge and fulfill these correctly. Currently for display only; only the cap itself adds to cart.</p>
        {%- endif -%}

        {%- form 'product', product, id: 'thrivve-hero-product-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="thrivve-hero-variant-id">

          {%- if product.has_only_default_variant == false -%}
            <div class="thrivve-hero-product__variants">
              {%- for option in product.options_with_values -%}
                <fieldset>
                  <legend>{{ option.name }}</legend>
                  <select name="options[{{ option.name | escape }}]" class="thrivve-hero-variant-select">
                    {%- for value in option.values -%}
                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                    {%- endfor -%}
                  </select>
                </fieldset>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="thrivve-hero-product__quantity">
            <label for="thrivve-hero-quantity">Qty</label>
            <input type="number" id="thrivve-hero-quantity" name="quantity" value="1" min="1">
          </div>

          <button type="submit" class="thrivve-hero-product__buy-button" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            {%- if product.selected_or_first_available_variant.available -%}
              {{ section.settings.button_label | default: 'Add to Cart' }}
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        {%- endform -%}

        {%- if section.settings.guarantee_text != blank -%}
          <p class="thrivve-hero-product__guarantee">{{ section.settings.guarantee_text }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    <p style="text-align:center; padding: 4rem 0; opacity: 0.6;">Select a product in the section settings to display it here.</p>
  {%- endif -%}
</div>

<script>
  (function() {
    var section = document.currentScript.closest('.thrivve-hero-product') || document.querySelector('.thrivve-hero-product');
    if (!section) return;

    var thumbs = section.querySelectorAll('.thrivve-hero-product__thumb');
    var mainImg = document.getElementById('thrivve-hero-main-image');
    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbs.forEach(function(t) { t.classList.remove('is-active'); });
        thumb.classList.add('is-active');
        if (mainImg) {
          mainImg.src = thumb.getAttribute('data-full-src');
        }
      });
    });

    var tiers = section.querySelectorAll('[data-bundle-tier]');
    tiers.forEach(function(tier) {
      tier.querySelector('.thrivve-bundle-tier__header').addEventListener('click', function() {
        tiers.forEach(function(t) { t.classList.remove('is-selected'); });
        tier.classList.add('is-selected');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Thrivve Hero Product",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#e8492a"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "Show review badge",
      "default": true
    },
    {
      "type": "text",
      "id": "review_rating",
      "label": "Rating out of 5",
      "default": "0.0"
    },
    {
      "type": "number",
      "id": "review_count",
      "label": "Review count",
      "default": 0
    },
    {
      "type": "header",
      "content": "Benefit bullets"
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1",
      "default": "🔴 Dual-wavelength red light therapy"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2",
      "default": "⚡ 15-minute daily sessions"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefit 3",
      "default": "🧢 Lightweight, hands-free comfort"
    },
    {
      "type": "header",
      "content": "Bundle tiers (placeholder pricing — wire up a bundle app for real checkout)"
    },
    {
      "type": "checkbox",
      "id": "show_bundles",
      "label": "Show bundle tier selector",
      "default": false
    },
    {
      "type": "header",
      "content": "Inventory urgency"
    },
    {
      "type": "checkbox",
      "id": "show_inventory",
      "label": "Show low-stock message (uses real, live inventory — requires inventory tracking turned on for this product)",
      "default": false
    },
    {
      "type": "number",
      "id": "low_stock_threshold",
      "label": "Show message when stock is at or below",
      "default": 10
    },
    {
      "type": "header",
      "content": "Buy box"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee line",
      "default": "30-Day Money-Back Guarantee · Free Shipping Over $50"
    }
  ],
  "blocks": [
    {
      "type": "bundle_tier",
      "name": "Bundle tier",
      "settings": [
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (e.g. MOST POPULAR) — leave blank for none"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Tier name",
          "default": "Starter"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Red Light Therapy Cap"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price (number only, e.g. 79.99)",
          "default": "79.99"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare-at price (optional, number only)"
        },
        {
          "type": "text",
          "id": "item_1_name",
          "label": "Included item 1 (optional)"
        },
        {
          "type": "text",
          "id": "item_2_name",
          "label": "Included item 2 (optional)"
        }
      ]
    },
    {
      "type": "addon",
      "name": "Add-on checkbox",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shipping Protection"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price (number only)",
          "default": "4.40"
        },
        {
          "type": "checkbox",
          "id": "checked_by_default",
          "label": "Checked by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Hero Product"
    }
  ]
}
{% endschema %}
