<section class="ks-collections">
  <div class="ks-collections-inner">
    <div class="ks-section-header">
      <span class="ks-section-eyebrow">Shop By Collection</span>
      <h2 class="ks-section-title">Wear The Word</h2>
    </div>
    <div class="ks-collections-grid">
      <div class="ks-collection-card">
        <div class="ks-collection-bg ks-collection-bg-1"></div>
        <div class="ks-collection-icon">✝</div>
        <div class="ks-collection-overlay"></div>
        <div class="ks-collection-content">
          <p class="ks-collection-tag">Best Sellers</p>
          <h3 class="ks-collection-name">Necklaces</h3>
          <a href="/collections/best-sellers" class="ks-collection-link">Shop Now →</a>
        </div>
      </div>
      <div class="ks-collection-card">
        <div class="ks-collection-bg ks-collection-bg-2"></div>
        <div class="ks-collection-icon">⛓</div>
        <div class="ks-collection-overlay"></div>
        <div class="ks-collection-content">
          <p class="ks-collection-tag">New In</p>
          <h3 class="ks-collection-name">Chains & Bracelets</h3>
          <a href="/collections/best-sellers" class="ks-collection-link">Shop Now →</a>
        </div>
      </div>
      <div class="ks-collection-card">
        <div class="ks-collection-bg ks-collection-bg-3"></div>
        <div class="ks-collection-icon">🎁</div>
        <div class="ks-collection-overlay"></div>
        <div class="ks-collection-content">
          <p class="ks-collection-tag">Gift Ideas</p>
          <h3 class="ks-collection-name">Sets & Bundles</h3>
          <a href="/collections/best-sellers" class="ks-collection-link">Shop Now →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.ks-collections {
  padding: 100px 40px;
  background: #0A0A0A;
}
.ks-collections-inner {
  max-width: 1400px;
  margin: 0 auto;
}
.ks-section-header {
  text-align: center;
  margin-bottom: 60px;
}
.ks-section-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 5px;
  color: #C9A84C;
  text-transform: uppercase;
  margin-bottom: 12px;
  display: block;
}
.ks-section-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #FAFAF5;
}
.ks-collections-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.ks-collection-card {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  cursor: pointer;
  background: #1A1A1A;
}
.ks-collection-bg {
  position: absolute;
  inset: 0;
  transition: transform 0.6s ease;
}
.ks-collection-card:hover .ks-collection-bg { transform: scale(1.05); }
.ks-collection-bg-1 {
  background: linear-gradient(135deg, #1a1206 0%, #2d1f08 40%, #1a1206 100%);
}
.ks-collection-bg-2 {
  background: linear-gradient(135deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
}
.ks-collection-bg-3 {
  background: linear-gradient(135deg, #0d1a12 0%, #142b1c 50%, #0d1a12 100%);
}
.ks-collection-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 100px;
  opacity: 0.08;
  color: #C9A84C;
  transition: opacity 0.3s;
}
.ks-collection-card:hover .ks-collection-icon { opacity: 0.15; }
.ks-collection-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
}
.ks-collection-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30px;
}
.ks-collection-tag {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  color: #C9A84C;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.ks-collection-name {
  font-family: 'Cinzel', serif;
  font-size: 22px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #FAFAF5;
  margin-bottom: 12px;
}
.ks-collection-link {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  color: #C9A84C;
  text-transform: uppercase;
  text-decoration: none;
  border-bottom: 1px solid rgba(201,168,76,0.4);
  padding-bottom: 2px;
  transition: all 0.2s;
}
.ks-collection-link:hover { border-color: #C9A84C; }
@media (max-width: 768px) {
  .ks-collections-grid { grid-template-columns: 1fr; }
  .ks-collections { padding: 60px 20px; }
}
</style>

{% schema %}
{
  "name": "KS Collections",
  "settings": [],
  "presets": [{ "name": "KS Collections" }]
}
{% endschema %}
