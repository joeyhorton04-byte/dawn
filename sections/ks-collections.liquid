<section class="thr-collections">
  <div class="thr-collections-inner">
    <h2 class="thr-collections-heading">{{ section.settings.heading | default: 'Shop The System' }}</h2>
    <p class="thr-collections-sub">{{ section.settings.subheading | default: 'Everything you need for a simple, daily scalp care routine.' }}</p>

    <div class="thr-collections-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.product_link }}" class="thr-collection-card">
          <div class="thr-collection-image">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: '600x' }}" alt="{{ block.settings.title | escape }}">
            {% endif %}
          </div>
          <div class="thr-collection-info">
            <h3>{{ block.settings.title }}</h3>
            <div class="thr-collection-price-row">
              <span class="thr-collection-price">{{ block.settings.price }}</span>
              {% if block.settings.compare_price != blank %}
                <span class="thr-collection-compare">{{ block.settings.compare_price }}</span>
              {% endif %}
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.thr-collections {
  background: #FFFFFF;
  padding: 60px 32px;
}
.thr-collections-inner {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}
.thr-collections-heading {
  font-family: 'Inter', sans-serif;
  font-size: 30px;
  font-weight: 800;
  color: #111;
  margin-bottom: 10px;
}
.thr-collections-sub {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: #666;
  margin-bottom: 36px;
}
.thr-collections-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  text-align: left;
}
.thr-collection-card {
  display: block;
  text-decoration: none;
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 12px;
  overflow: hidden;
  transition: border-color 0.2s, transform 0.2s;
}
.thr-collection-card:hover { border-color: #E63946; transform: translateY(-2px); }
.thr-collection-image {
  width: 100%;
  aspect-ratio: 1;
  background: #F4F4F4;
}
.thr-collection-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
.thr-collection-info { padding: 16px; }
.thr-collection-info h3 {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 700;
  color: #111;
  margin: 0 0 8px;
}
.thr-collection-price-row { display: flex; align-items: center; gap: 8px; }
.thr-collection-price { font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 800; color: #E63946; }
.thr-collection-compare { font-family: 'Inter', sans-serif; font-size: 12px; color: #999; text-decoration: line-through; }

@media (max-width: 768px) {
  .thr-collections { padding: 36px 16px; }
  .thr-collections-heading { font-size: 22px; }
  .thr-collections-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
}
</style>

{% schema %}
{
  "name": "Thrivve Collections",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop The System" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Everything you need for a simple, daily scalp care routine." }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Red Light Therapy Cap" },
        { "type": "text", "id": "price", "label": "Price", "default": "$80.00" },
        { "type": "text", "id": "compare_price", "label": "Compare-at price" },
        { "type": "url", "id": "product_link", "label": "Product link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Collections",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
