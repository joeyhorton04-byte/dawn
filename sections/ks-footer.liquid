<footer class="thr-footer">
  <div class="thr-footer-inner">
    <div class="thr-footer-col">
      <a href="/" class="thr-footer-logo">THRIVVE <span>LABS</span></a>
      <p class="thr-footer-tagline">Simple, hands-free red light therapy for everyday scalp care.</p>
    </div>

    <div class="thr-footer-col">
      <h4>Shop</h4>
      <a href="/collections/all">All Products</a>
      <a href="/products">Red Light Cap</a>
    </div>

    <div class="thr-footer-col">
      <h4>Support</h4>
      <a href="/pages/track-order">Track Your Order</a>
      <a href="/pages/contact">Contact</a>
      <a href="/pages/faq">FAQ</a>
      <a href="/pages/returns">Returns & Warranty</a>
    </div>

    <div class="thr-footer-col">
      <h4>Legal</h4>
      <a href="/policies/privacy-policy">Privacy Policy</a>
      <a href="/policies/terms-of-service">Terms of Service</a>
      <a href="/policies/shipping-policy">Shipping Policy</a>
    </div>
  </div>

  <div class="thr-footer-bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} Thrivve Labs. All rights reserved.</span>
  </div>
</footer>

<style>
.thr-footer {
  background: #0B0B0B;
  color: #BBBBBB;
  padding: 48px 32px 24px;
}
.thr-footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1fr;
  gap: 32px;
}
.thr-footer-logo {
  font-family: 'Archivo Black', sans-serif;
  font-size: 18px;
  color: #FFFFFF;
  text-decoration: none;
  letter-spacing: 0.5px;
  display: block;
  margin-bottom: 12px;
}
.thr-footer-logo span { color: #E63946; }
.thr-footer-tagline {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: #999;
  line-height: 1.6;
  max-width: 260px;
}
.thr-footer-col h4 {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: #FFFFFF;
  margin-bottom: 14px;
}
.thr-footer-col a {
  display: block;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: #999;
  text-decoration: none;
  margin-bottom: 10px;
}
.thr-footer-col a:hover { color: #E63946; }
.thr-footer-bottom {
  max-width: 1200px;
  margin: 36px auto 0;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.08);
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: #777;
  text-align: center;
}

@media (max-width: 768px) {
  .thr-footer { padding: 32px 18px 18px; }
  .thr-footer-inner { grid-template-columns: 1fr 1fr; gap: 24px; }
}
</style>

{% schema %}
{
  "name": "Thrivve Footer",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [{ "name": "Thrivve Footer" }]
}
{% endschema %}
