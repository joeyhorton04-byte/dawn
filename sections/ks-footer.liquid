<style>
.ks-footer {
  background: #050505;
  border-top: 1px solid rgba(201,168,76,0.15);
  padding: 60px 20px 32px;
  color: #888888;
}
.ks-footer-inner {
  max-width: 1200px;
  margin: 0 auto 48px;
  display: flex;
  flex-direction: column;
  gap: 48px;
}
.ks-footer-logo {
  font-family: 'Cinzel', serif;
  font-size: 20px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #C9A84C;
  margin-bottom: 12px;
}
.ks-footer-tagline {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 15px;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 12px;
}
.ks-footer-ministry {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #C9A84C;
}
.ks-footer-links {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 32px;
}
.ks-footer-col h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #C9A84C;
  margin-bottom: 20px;
}
.ks-footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.ks-footer-col ul li {
  margin-bottom: 12px;
}
.ks-footer-col ul li a {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  color: #888888;
  text-decoration: none;
  transition: color 0.2s;
}
.ks-footer-col ul li a:hover {
  color: #C9A84C;
}
.ks-footer-bottom {
  max-width: 1200px;
  margin: 0 auto;
  border-top: 1px solid rgba(201,168,76,0.1);
  padding-top: 24px;
  text-align: center;
}
.ks-footer-bottom p {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #444444;
}

/* TABLET */
@media (min-width: 768px) {
  .ks-footer {
    padding: 80px 40px 40px;
  }
  .ks-footer-inner {
    flex-direction: row;
    align-items: flex-start;
    gap: 60px;
  }
  .ks-footer-brand {
    flex: 0 0 280px;
  }
  .ks-footer-links {
    flex: 1;
  }
}

/* MOBILE */
@media (max-width: 767px) {
  .ks-footer-links {
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .ks-footer-col:last-child {
    grid-column: 1 / -1;
  }
  .ks-footer-col ul li a {
    font-size: 15px;
  }
}
</style>

