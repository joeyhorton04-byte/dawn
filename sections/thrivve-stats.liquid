<style>
  .thrivve-stats {
    padding: 4rem 0;
    text-align: center;
  }
  .thrivve-stats__heading {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .thrivve-stats__caption {
    font-size: 1.5rem;
    opacity: 0.7;
    max-width: 560px;
    margin: 0 auto 3.6rem;
  }
  .thrivve-stats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3.2rem;
  }
  .thrivve-stats__number {
    font-size: 4.6rem;
    font-weight: 700;
    color: var(--thrivve-accent, #e8492a);
    margin-bottom: 0.8rem;
  }
  .thrivve-stats__desc {
    font-size: 1.4rem;
    opacity: 0.75;
    max-width: 240px;
    margin: 0 auto;
  }
  .thrivve-stats__disclaimer {
    font-size: 1.2rem;
    opacity: 0.5;
    margin-top: 3.2rem;
  }
  @media screen and (max-width: 749px) {
    .thrivve-stats__grid {
      grid-template-columns: 1fr;
      gap: 2.4rem;
    }
  }
</style>

<div class="thrivve-stats color-{{ section.settings.color_scheme }} page-width">
  {% if section.settings.heading != blank %}
    <h2 class="thrivve-stats__heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}
  {% if section.settings.caption != blank %}
    <p class="thrivve-stats__caption">{{ section.settings.caption }}</p>
  {% endif %}

  <div class="thrivve-stats__grid">
    {% for block in section.blocks %}
      {% if block.type == 'stat' %}
        <div {{ block.shopify_attributes }}>
          <div class="thrivve-stats__number">{{ block.settings.number | escape }}</div>
          <p class="thrivve-stats__desc">{{ block.settings.description | escape }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.show_disclaimer %}
    <p class="thrivve-stats__disclaimer">{{ section.settings.disclaimer_text }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Thrivve Stats",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Results"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "checkbox",
      "id": "show_disclaimer",
      "label": "Show disclaimer",
      "default": true
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer text",
      "default": "Based on internal customer survey data. Individual results vary. Replace with real data once available — do not publish stats you cannot substantiate."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number (placeholder — replace with real data)",
          "default": "00%"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Replace with a real, verifiable stat once you have survey or review data."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Stats",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" }
      ]
    }
  ]
}
{% endschema %}
