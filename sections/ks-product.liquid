<section class="thr-product">
  <div class="thr-product-inner">

    <!-- IMAGE GALLERY -->
    <div class="thr-product-gallery">
      <div class="thr-product-main-image">
        {% if product.featured_image %}
          <img id="thr-main-img" src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}">
        {% endif %}
        <div class="thr-gallery-nav">
          <button class="thr-prev" onclick="thrPrevImage()" aria-label="Previous image">&#8592;</button>
          <button class="thr-next" onclick="thrNextImage()" aria-label="Next image">&#8594;</button>
        </div>
      </div>
      {% if product.images.size > 1 %}
        <div class="thr-thumb-row">
          {% for image in product.images %}
            <button class="thr-thumb-btn {% if forloop.first %}active{% endif %}" onclick="thrGoToImage({{ forloop.index0 }}, this)">
              <img src="{{ image | img_url: '200x' }}" alt="{{ product.title }} thumbnail {{ forloop.index }}">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- PRODUCT INFO -->
    <div class="thr-product-info">

      <div class="thr-product-reviews">
        <span class="thr-stars">★★★★☆</span>
        <span class="thr-review-count">4.42/5 (593 Reviews)</span>
      </div>

      <h1 class="thr-product-title">{{ product.title }}</h1>

      <div class="thr-price-row">
        <span class="thr-price">{{ product.selected_or_first_available_variant.price | money }}</span>
        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <span class="thr-compare-price">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
          <span class="thr-save-badge">SAVE 40%</span>
        {% endif %}
      </div>

      <ul class="thr-feature-list">
        <li>🔴 Easy daily scalp care</li>
        <li>💪 Red light therapy support</li>
        <li>☀️ Lightweight, hands-free comfort</li>
      </ul>

      <div class="thr-stock-banner">ONLY 6 LEFT IN STOCK!</div>

      <!-- BUNDLE / UPSELL BOX -->
      <div class="thr-bundle-box">
        <div class="thr-bundle-option selected" onclick="thrSelectBundle(this)">
          <span class="thr-radio"></span>
          <div class="thr-bundle-text">
            <div class="thr-bundle-name">Starter System</div>
            <div class="thr-bundle-sub">Red Light Therapy Cap</div>
          </div>
          <div class="thr-bundle-price">
            <span class="thr-bundle-now">{{ product.selected_or_first_available_variant.price | money }}</span>
            {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
              <span class="thr-bundle-was">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
            {% endif %}
          </div>
        </div>

        <div class="thr-bundle-product-row">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: '100x' }}" alt="{{ product.title }}">
          {% endif %}
          <div class="thr-bundle-text">
            <div class="thr-bundle-name">{{ product.title }}</div>
          </div>
          <div class="thr-bundle-price">
            <span class="thr-bundle-now">{{ product.selected_or_first_available_variant.price | money }}</span>
            {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
              <span class="thr-bundle-was">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
            {% endif %}
          </div>
        </div>

        <label class="thr-addon-row">
          <input type="checkbox" id="thr-shipping-protection" checked>
          <span class="thr-addon-icon">🛡️</span>
          <span class="thr-addon-text">+ Shipping Protection</span>
          <span class="thr-addon-price">$4.40</span>
        </label>

        <label class="thr-addon-row">
          <input type="checkbox" id="thr-warranty" checked>
          <span class="thr-addon-icon">⏱️</span>
          <span class="thr-addon-text">+ 30-Day Warranty</span>
          <span class="thr-addon-price">$4.40</span>
        </label>
      </div>

      <!-- VARIANT SELECTOR -->
      {% for option in product.options_with_values %}
        {% if option.values.size > 1 %}
          <p class="thr-variant-label">{{ option.name }}</p>
          <div class="thr-variants">
            {% for value in option.values %}
              <button
                type="button"
                class="thr-pill-btn {% if forloop.first %}active{% endif %}"
                onclick="thrSelectVariant(this, '{{ value }}')"
                data-value="{{ value }}"
              >{{ value }}</button>
            {% endfor %}
          </div>
        {% endif %}
      {% endfor %}

      {% form 'product', product %}
        <input type="hidden" name="id" id="thr-variant-id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" name="add" class="thr-add-to-cart">
          ADD TO CART — <span id="thr-cta-total">{{ product.selected_or_first_available_variant.price | money }}</span>
        </button>
      {% endform %}

      <div class="thr-trust-row">
        <span>🔒 Secure Checkout</span>
        <span>🚚 Free Shipping Over $50</span>
        <span>↩️ 30-Day Returns</span>
      </div>

      <div class="thr-product-accordion">
        <div class="thr-accordion-item open">
          <div class="thr-accordion-header" onclick="thrToggle(this)">
            Product Details <span class="thr-accordion-arrow">▼</span>
          </div>
          <div class="thr-accordion-body">{{ product.description }}</div>
        </div>
        <div class="thr-accordion-item">
          <div class="thr-accordion-header" onclick="thrToggle(this)">
            How It Works <span class="thr-accordion-arrow">▼</span>
          </div>
          <div class="thr-accordion-body">Red and near-infrared LEDs are positioned along the inner brim for hands-free, daily scalp exposure. Use for 10–15 minutes per session, 3–5 times per week.</div>
        </div>
        <div class="thr-accordion-item">
          <div class="thr-accordion-header" onclick="thrToggle(this)">
            Shipping & Returns <span class="thr-accordion-arrow">▼</span>
          </div>
          <div class="thr-accordion-body">Orders processed within 24–72 hours. Ships worldwide in 5–10 business days. 30-day returns. Email support@thrivvelabs.com.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- STICKY MOBILE CTA -->
  <div class="thr-sticky-cta">
    <div class="thr-sticky-info">
      <span class="thr-sticky-price">{{ product.selected_or_first_available_variant.price | money }}</span>
      <span class="thr-sticky-was">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
    </div>
    <button type="button" class="thr-sticky-btn" onclick="document.querySelector('.thr-add-to-cart').click()">ADD TO CART</button>
  </div>
</section>

<style>
.thr-product {
  padding: 60px 40px 100px;
  background: #FFFFFF;
  font-family: 'Inter', sans-serif;
  color: #111111;
}
.thr-product-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}

/* GALLERY */
.thr-product-main-image {
  width: 100%;
  aspect-ratio: 1;
  background: #F4F4F4;
  border-radius: 12px;
  position: relative;
  overflow: hidden;
}
.thr-product-main-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.3s;
}
.thr-gallery-nav {
  position: absolute;
  bottom: 16px;
  right: 16px;
  display: flex;
  gap: 8px;
  z-index: 2;
}
.thr-prev, .thr-next {
  width: 36px;
  height: 36px;
  background: rgba(255,255,255,0.9);
  border: 1px solid rgba(0,0,0,0.1);
  border-radius: 50%;
  color: #111;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.thr-prev:hover, .thr-next:hover { background: #E63946; color: #fff; }
.thr-thumb-row { display: flex; gap: 10px; margin-top: 12px; }
.thr-thumb-btn { width: 64px; height: 64px; border-radius: 8px; overflow: hidden; border: 2px solid transparent; cursor: pointer; padding: 0; background: none; }
.thr-thumb-btn.active { border-color: #E63946; }
.thr-thumb-btn img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* INFO */
.thr-product-reviews { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
.thr-stars { color: #FFB400; font-size: 16px; letter-spacing: 1px; }
.thr-review-count { font-size: 13px; color: #555; font-weight: 600; }

.thr-product-title {
  font-family: 'Inter', sans-serif;
  font-size: 32px;
  font-weight: 800;
  color: #111;
  line-height: 1.15;
  margin-bottom: 16px;
}

.thr-price-row { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
.thr-price { font-size: 28px; font-weight: 800; color: #E63946; }
.thr-compare-price { font-size: 18px; color: #999; text-decoration: line-through; }
.thr-save-badge { background: #E63946; color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; padding: 4px 10px; border-radius: 20px; }

.thr-feature-list { list-style: none; padding: 0; margin: 0 0 18px; display: flex; flex-direction: column; gap: 8px; }
.thr-feature-list li { font-size: 14px; font-weight: 600; color: #333; }

.thr-stock-banner {
  background: rgba(230,57,70,0.08);
  border: 1px solid rgba(230,57,70,0.3);
  color: #E63946;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.5px;
  text-align: center;
  padding: 10px;
  border-radius: 8px;
  margin-bottom: 20px;
}

/* BUNDLE BOX */
.thr-bundle-box {
  border: 2px solid #E63946;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 24px;
}
.thr-bundle-option, .thr-bundle-product-row, .thr-addon-row {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 18px;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}
.thr-bundle-option { background: rgba(230,57,70,0.06); cursor: pointer; }
.thr-radio { width: 18px; height: 18px; border-radius: 50%; border: 2px solid #E63946; background: #E63946; flex-shrink: 0; position: relative; }
.thr-radio::after { content: ''; position: absolute; top: 4px; left: 4px; width: 6px; height: 6px; border-radius: 50%; background: #fff; }
.thr-bundle-text { flex: 1; }
.thr-bundle-name { font-size: 14px; font-weight: 700; color: #111; }
.thr-bundle-sub { font-size: 12px; color: #777; }
.thr-bundle-price { text-align: right; }
.thr-bundle-now { font-size: 14px; font-weight: 800; color: #111; }
.thr-bundle-was { font-size: 12px; color: #999; text-decoration: line-through; margin-left: 6px; }
.thr-bundle-product-row img { width: 44px; height: 44px; border-radius: 6px; object-fit: cover; }
.thr-addon-row { cursor: pointer; background: rgba(230,57,70,0.04); }
.thr-addon-row:last-child { border-bottom: none; }
.thr-addon-row input[type="checkbox"] { width: 18px; height: 18px; accent-color: #E63946; flex-shrink: 0; }
.thr-addon-icon { font-size: 16px; }
.thr-addon-text { flex: 1; font-size: 13px; font-weight: 700; color: #111; }
.thr-addon-price { font-size: 13px; font-weight: 700; color: #111; }

/* VARIANTS */
.thr-variant-label { font-size: 12px; font-weight: 700; color: #555; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 10px; }
.thr-variants { display: flex; gap: 10px; margin-bottom: 22px; flex-wrap: wrap; }
.thr-pill-btn {
  padding: 10px 18px;
  border-radius: 8px;
  border: 1.5px solid rgba(0,0,0,0.15);
  background: #fff;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}
.thr-pill-btn.active, .thr-pill-btn:hover { border-color: #E63946; color: #E63946; }

/* CTA */
.thr-add-to-cart {
  width: 100%;
  padding: 18px;
  background: #E63946;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 800;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s;
  margin-bottom: 18px;
}
.thr-add-to-cart:hover { background: #c92b38; }

.thr-trust-row { display: flex; justify-content: space-between; gap: 8px; font-size: 11px; color: #777; font-weight: 600; margin-bottom: 32px; flex-wrap: wrap; }

/* ACCORDION */
.thr-product-accordion { border-top: 1px solid rgba(0,0,0,0.08); }
.thr-accordion-item { border-bottom: 1px solid rgba(0,0,0,0.08); }
.thr-accordion-header {
  padding: 16px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  font-size: 13px;
  font-weight: 700;
  color: #333;
}
.thr-accordion-header:hover { color: #E63946; }
.thr-accordion-arrow { transition: transform 0.3s; font-size: 10px; }
.thr-accordion-body { padding: 0 0 18px; font-size: 14px; color: #666; line-height: 1.7; display: none; }
.thr-accordion-item.open .thr-accordion-body { display: block; }
.thr-accordion-item.open .thr-accordion-arrow { transform: rotate(180deg); }

/* STICKY MOBILE CTA */
.thr-sticky-cta {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0,0,0,0.1);
  padding: 12px 16px;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  z-index: 50;
  box-shadow: 0 -4px 16px rgba(0,0,0,0.08);
}
.thr-sticky-info { display: flex; align-items: baseline; gap: 8px; }
.thr-sticky-price { font-size: 16px; font-weight: 800; color: #E63946; }
.thr-sticky-was { font-size: 12px; color: #999; text-decoration: line-through; }
.thr-sticky-btn {
  background: #E63946;
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 12px 20px;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  cursor: pointer;
}

@media (max-width: 768px) {
  .thr-product { padding: 24px 16px 90px; }
  .thr-product-inner { grid-template-columns: 1fr; gap: 24px; }
  .thr-product-title { font-size: 22px; }
  .thr-price { font-size: 22px; }
  .thr-sticky-cta { display: flex; }
}
</style>

<script>
const thrImages = [
  {% for image in product.images %}
    "{{ image | img_url: 'master' }}"{% unless forloop.last %},{% endunless %}
  {% endfor %}
];

let thrCurrentIndex = 0;

function thrSetMainImage(src) {
  const img = document.getElementById('thr-main-img');
  if (!img) return;
  img.style.opacity = '0';
  setTimeout(() => { img.src = src; img.style.opacity = '1'; }, 200);
}

function thrNextImage() {
  if (!thrImages.length) return;
  thrCurrentIndex = (thrCurrentIndex + 1) % thrImages.length;
  thrSetMainImage(thrImages[thrCurrentIndex]);
  thrSyncThumbs();
}

function thrPrevImage() {
  if (!thrImages.length) return;
  thrCurrentIndex = (thrCurrentIndex - 1 + thrImages.length) % thrImages.length;
  thrSetMainImage(thrImages[thrCurrentIndex]);
  thrSyncThumbs();
}

function thrGoToImage(index, btn) {
  thrCurrentIndex = index;
  thrSetMainImage(thrImages[index]);
  document.querySelectorAll('.thr-thumb-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function thrSyncThumbs() {
  document.querySelectorAll('.thr-thumb-btn').forEach((b, i) => {
    b.classList.toggle('active', i === thrCurrentIndex);
  });
}

function thrSelectVariant(btn, variantTitle) {
  document.querySelectorAll('.thr-pill-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  {% for variant in product.variants %}
    if (variantTitle === "{{ variant.title }}") {
      document.getElementById('thr-variant-id').value = "{{ variant.id }}";
      {% if variant.featured_image %}
        const idx = thrImages.indexOf("{{ variant.featured_image | img_url: 'master' }}");
        if (idx !== -1) { thrCurrentIndex = idx; thrSetMainImage(thrImages[idx]); thrSyncThumbs(); }
      {% endif %}
    }
  {% endfor %}
}

function thrSelectBundle(el) {
  document.querySelectorAll('.thr-bundle-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
}

function thrToggle(header) {
  const item = header.parentElement;
  const wasOpen = item.classList.contains('open');
  document.querySelectorAll('.thr-accordion-item').forEach(i => i.classList.remove('open'));
  if (!wasOpen) item.classList.add('open');
}
</script>

{% schema %}
{
  "name": "Thrivve Product",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [],
  "presets": [{ "name": "Thrivve Product" }]
}
{% endschema %}
