<div class="thr-announce">
  <div class="thr-announce-track">
    {% for i in (1..6) %}
      <span class="thr-announce-item">⚡ FREE SHIPPING OVER $50</span>
      <span class="thr-announce-item">🛡️ 30-DAY MONEY-BACK GUARANTEE</span>
      <span class="thr-announce-item">⭐ 4.4/5 FROM 500+ CUSTOMERS</span>
      <span class="thr-announce-item">🔴 FDA-REGISTERED RED LIGHT THERAPY</span>
    {% endfor %}
  </div>
</div>

<style>
.thr-announce {
  background: #0B0B0B;
  color: #FFFFFF;
  overflow: hidden;
  white-space: nowrap;
  padding: 10px 0;
}
.thr-announce-track {
  display: inline-flex;
  animation: thr-marquee 30s linear infinite;
}
.thr-announce-item {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  padding: 0 28px;
  border-right: 1px solid rgba(255,255,255,0.15);
}
@keyframes thr-marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
@media (max-width: 768px) {
  .thr-announce-item { font-size: 11px; padding: 0 18px; }
}
</style>

{% schema %}
{
  "name": "Thrivve Announcement",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [{ "name": "Thrivve Announcement" }]
}
{% endschema %}
