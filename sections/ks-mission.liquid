.thrivve-mission__inner {
  max-width: 760px;
  margin: 0 auto;
  text-align: center;
}

.thrivve-mission__eyebrow {
  font-size: 1.3rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1.2rem;
  opacity: 0.75;
}

.thrivve-mission__heading {
  font-size: 3.2rem;
  line-height: 1.15;
  margin-bottom: 2rem;
}

.thrivve-mission__body {
  font-size: 1.6rem;
  line-height: 1.7;
  opacity: 0.85;
  text-align: left;
}

.thrivve-mission__body p {
  margin-bottom: 1.6rem;
}

.thrivve-mission__body p:last-child {
  margin-bottom: 0;
}

@media screen and (max-width: 749px) {
  .thrivve-mission__heading {
    font-size: 2.6rem;
  }
}
