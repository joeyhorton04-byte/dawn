<section class="thr-mission">
  <div class="thr-mission-inner">
    <div class="thr-mission-image">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading | escape }}">
      {% endif %}
    </div>
    <div class="thr-mission-content">
      <h2 class="thr-mission-heading">{{ section.settings.heading | default: 'Built For Real Daily Routines' }}</h2>
      <p class="thr-mission-text">
        {{ section.settings.body | default: 'We built Thrivve Labs because scalp care shouldn\'t require an hour of your day. Our Red Light Therapy Cap fits into the moments you already have — relaxing, working, watching TV — so consistency actually happens.' }}
      </p>
      <a href="{{ section.settings.button_link | default: '/products' }}" class="thr-mission-cta">
        {{ section.settings.button_text | default: 'Shop The Cap' }}
      </a>
    </div>
  </div>
</section>

<style>
.thr-mission {
  background: #FFFFFF;
  padding: 60px 32px;
}
.thr-mission-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 56px;
  align-items: center;
}
.thr-mission-image {
  width: 100%;
  aspect-ratio: 1;
  background: #F4F4F4;
  border-radius: 16px;
  overflow: hidden;
}
.thr-mission-image img { width: 100%; height: 100%; object-fit: cover; }
.thr-mission-heading {
  font-family: 'Inter', sans-serif;
  font-size: 28px;
  font-weight: 800;
  color: #111;
  margin-bottom: 18px;
}
.thr-mission-text {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: #555;
  line-height: 1.7;
  margin-bottom: 24px;
}
.thr-mission-cta {
  display: inline-block;
  background: #E63946;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 14px 30px;
  border-radius: 10px;
  transition: background 0.2s;
}
.thr-mission-cta:hover { background: #c92b38; }

@media (max-width: 768px) {
  .thr-mission { padding: 36px 16px; }
  .thr-mission-inner { grid-template-columns: 1fr; gap: 24px; }
  .thr-mission-heading { font-size: 22px; }
}
</style>

{% schema %}
{
  "name": "Thrivve Mission",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built For Real Daily Routines" },
    { "type": "textarea", "id": "body", "label": "Body text" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop The Cap" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Thrivve Mission" }]
}
{% endschema %}
