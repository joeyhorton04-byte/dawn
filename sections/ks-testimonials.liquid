.thrivve-testimonials__heading {
  text-align: center;
  font-size: 3rem;
  margin-bottom: 3.2rem;
}

.thrivve-testimonials__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2.4rem;
}

.thrivve-testimonial-card {
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 8px;
  padding: 2.8rem;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}

.thrivve-testimonial-card__stars {
  font-size: 1.8rem;
  letter-spacing: 0.15em;
  color: #f5a623;
}

.thrivve-testimonial-card__title {
  font-size: 1.8rem;
  line-height: 1.3;
  margin: 0;
}

.thrivve-testimonial-card__body {
  font-size: 1.5rem;
  line-height: 1.6;
  opacity: 0.85;
  margin: 0;
}

.thrivve-testimonial-card__author {
  font-size: 1.4rem;
  font-weight: 600;
  opacity: 0.7;
  margin: 0;
}

@media screen and (max-width: 989px) {
  .thrivve-testimonials__grid {
    grid-template-columns: 1fr;
  }
}
