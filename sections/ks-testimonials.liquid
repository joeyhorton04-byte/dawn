<section class="thr-testimonials">
  <div class="thr-testimonials-inner">
    <h2 class="thr-testimonials-heading">{{ section.settings.heading | default: 'What Our Customers Say' }}</h2>
    <div class="thr-testimonials-overall">
      <span class="thr-testimonials-stars">★★★★☆</span>
      <span>4.42/5 from 593 Reviews</span>
    </div>

    <div class="thr-testimonials-grid">
      {% for block in section.blocks %}
        <div class="thr-testimonial-card">
          <span class="thr-testimonial-stars">★★★★★</span>
          <p class="thr-testimonial-text">{{ block.settings.review }}</p>
          <span class="thr-testimonial-name">{{ block.settings.name }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.thr-testimonials {
  background: #F7F7F7;
  padding: 60px 32px;
}
.thr-testimonials-inner {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}
.thr-testimonials-heading {
  font-family: 'Inter', sans-serif;
  font-size: 28px;
  font-weight: 800;
  color: #111;
  margin-bottom: 12px;
}
.thr-testimonials-overall {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  margin-bottom: 36px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: #555;
  font-weight: 600;
}
.thr-testimonials-stars { color: #FFB400; font-size: 18px; }
.thr-testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  text-align: left;
}
.thr-testimonial-card {
  background: #FFFFFF;
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 12px;
  padding: 24px;
}
.thr-testimonial-stars { color: #FFB400; font-size: 14px; display: block; margin-bottom: 12px; }
.thr-testimonial-text {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: #333;
  line-height: 1.6;
  margin: 0 0 14px;
}
.thr-testimonial-name {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: #111;
}

@media (max-width: 768px) {
  .thr-testimonials { padding: 36px 16px; }
  .thr-testimonials-heading { font-size: 20px; }
  .thr-testimonials-grid { grid-template-columns: 1fr; gap: 14px; }
}
</style>

{% schema %}
{
  "name": "Thrivve Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "review", "label": "Review text", "default": "I just throw it on for about 20 minutes while I'm chilling watching TV. That's it. After a few months I started noticing real changes." },
        { "type": "text", "id": "name", "label": "Customer name", "default": "Jamie R." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review": "I just throw it on for about 20 minutes while I'm chilling watching TV. That's it. After a few months I started noticing real changes.",
            "name": "Jamie R."
          }
        },
        {
          "type": "review",
          "settings": {
            "review": "I was honestly skeptical at first. But after using it consistently for a few months, I started noticing less shedding and thicker-looking hair.",
            "name": "Michael T."
          }
        },
        {
          "type": "review",
          "settings": {
            "review": "I use it at night while scrolling on my phone. It's become part of my routine without even thinking about it. I could actually see the difference around my hairline.",
            "name": "Samantha L."
          }
        }
      ]
    }
  ]
}
{% endschema %}
