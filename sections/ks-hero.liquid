<section class="ks-hero">
  <div class="ks-hero-bg"></div>
  <div class="ks-hero-content">
    <p class="ks-eyebrow">✝ Kingdom Supply — Faith-Inspired Jewelry</p>
    <h1 class="ks-hero-title">
      Wear Your<br>
      <span class="ks-gold">Faith</span><br>
      Every Day
    </h1>
    <p class="ks-hero-sub">Premium Christian jewelry crafted to remind you who you live for.</p>
    <div class="ks-hero-ctas">
      <a href="/collections/best-sellers" class="ks-btn-primary">Shop The Collection</a>
      <a href="/pages/our-mission" class="ks-btn-secondary">Our Mission →</a>
    </div>
    <div class="ks-hero-stats">
      <div class="ks-stat">
        <span class="ks-stat-num">4.9★</span>
        <span class="ks-stat-label">Avg. Rating</span>
      </div>
      <div class="ks-stat">
        <span class="ks-stat-num">2K+</span>
        <span class="ks-stat-label">Happy Believers</span>
      </div>
      <div class="ks-stat">
        <span class="ks-stat-num">∞</span>
        <span class="ks-stat-label">Lifetime Guarantee</span>
      </div>
    </div>
  </div>
</section>

<style>
.ks-hero {
  background: #111111;
  position: relative;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 40px 24px 60px;
  min-height: 100svh;
}
.ks-hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(201,168,76,0.07) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}
.ks-hero-content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
}
.ks-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 3px;
  color: #C9A84C;
  text-transform: uppercase;
  margin-bottom: 20px;
  display: block;
  animation: ksFadeUp 0.8s forwards 0.2s;
}
.ks-hero-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(42px, 10vw, 96px);
  font-weight: 900;
  line-height: 1;
  text-transform: uppercase;
  color: #FAFAF5;
  margin-bottom: 20px;
  animation: ksFadeUp 0.8s forwards 0.4s;
}
.ks-gold { color: #C9A84C; }
.ks-hero-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(15px, 3vw, 20px);
  font-weight: 300;
  font-style: italic;
  color: #CCCCCC;
  line-height: 1.6;
  margin-bottom: 36px;
  max-width: 480px;
  animation: ksFadeUp 0.8s forwards 0.6s;
}
.ks-hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: center;
  animation: ksFadeUp 0.8s forwards 0.8s;
  margin-bottom: 48px;
}
.ks-btn-primary {
  background: #C9A84C;
  color: #0A0A0A;
  padding: 16px 32px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  text-decoration: none;
  display: inline-block;
  transition: background 0.25s;
}
.ks-btn-primary:hover { background: #E8C97A; }
.ks-btn-secondary {
  color: #C9A84C;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  border-bottom: 1px solid #C9A84C;
  padding-bottom: 2px;
}
.ks-hero-stats {
  display: flex;
  gap: 40px;
  animation: ksFadeUp 0.8s forwards 1s;
}
.ks-stat { text-align: left; }
.ks-stat-num {
  font-family: 'Cinzel', serif;
  font-size: 24px;
  font-weight: 700;
  color: #C9A84C;
  display: block;
}
.ks-stat-label {
  font-size: 9px;
  letter-spacing: 2px;
  color: #888888;
  text-transform: uppercase;
  display: block;
  margin-top: 2px;
}
@keyframes ksFadeUp {
  from { opacity: 0.3; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
}
@media (min-width: 769px) {
  .ks-hero { padding: 0 80px; }
  .ks-hero-title { font-size: 88px; line-height: 0.95; }
  .ks-hero-ctas { flex-wrap: nowrap; margin-bottom: 0; }
  .ks-hero-stats { gap: 48px; position: absolute; bottom: 60px; right: 80px; }
  .ks-stat-num { font-size: 32px; }
  .ks-stat-label { font-size: 10px; }
}
</style>

{% schema %}
{
  "name": "KS Hero",
  "settings": [],
  "presets": [{ "name": "KS Hero" }]
}
{% endschema %}
