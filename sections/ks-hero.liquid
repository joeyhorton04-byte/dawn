<section class="thr-hero">
  <div class="thr-hero-inner">
    <div class="thr-hero-image">
      {% if section.settings.hero_image != blank %}
        <img src="{{ section.settings.hero_image | img_url: 'master' }}" alt="{{ section.settings.heading | escape }}">
      {% endif %}
    </div>

    <div class="thr-hero-content">
      <div class="thr-hero-rating">
        <span class="thr-hero-stars">★★★★☆</span>
        <span class="thr-hero-rating-text">4.42/5 (593 Reviews)</span>
      </div>

      <h1 class="thr-hero-title">
        {{ section.settings.heading | default: 'Red Light Therapy. Hands-Free.' }}
      </h1>

      <p class="thr-hero-sub">
        {{ section.settings.subheading | default: 'Just put it on and go. Lightweight, breathable, and comfortable enough to wear every day — no complicated setup, no extra steps.' }}
      </p>

      <ul class="thr-hero-features">
        <li>🔴 Easy daily scalp care</li>
        <li>💪 Red light therapy support</li>
        <li>☀️ Lightweight, hands-free comfort</li>
      </ul>

      <div class="thr-hero-price-row">
        <span class="thr-hero-price">{{ section.settings.price | default: '$80.00' }}</span>
        <span class="thr-hero-compare">{{ section.settings.compare_price | default: '$134.00' }}</span>
        <span class="thr-hero-save">SAVE 40%</span>
      </div>

      <a href="{{ section.settings.button_link | default: '/products' }}" class="thr-hero-cta">
        {{ section.settings.button_text | default: 'Shop The Cap' }}
      </a>

      <div class="thr-hero-trust">
        <span>🔒 Secure Checkout</span>
        <span>🚚 Free Shipping Over $50</span>
        <span>↩️ 30-Day Returns</span>
      </div>
    </div>
  </div>
</section>

<style>
.thr-hero {
  background: #FFFFFF;
  padding: 60px 32px;
}
.thr-hero-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.thr-hero-image {
  width: 100%;
  aspect-ratio: 1;
  background: #F4F4F4;
  border-radius: 16px;
  overflow: hidden;
}
.thr-hero-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.thr-hero-rating {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}
.thr-hero-stars { color: #FFB400; font-size: 18px; letter-spacing: 1px; }
.thr-hero-rating-text { font-family: 'Inter', sans-serif; font-size: 13px; color: #555; font-weight: 600; }
.thr-hero-title {
  font-family: 'Inter', sans-serif;
  font-size: 42px;
  font-weight: 800;
  color: #111;
  line-height: 1.1;
  margin-bottom: 18px;
}
.thr-hero-sub {
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  color: #555;
  line-height: 1.6;
  margin-bottom: 24px;
  max-width: 480px;
}
.thr-hero-features {
  list-style: none;
  padding: 0;
  margin: 0 0 24px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.thr-hero-features li {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: #333;
}
.thr-hero-price-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
}
.thr-hero-price { font-family: 'Inter', sans-serif; font-size: 28px; font-weight: 800; color: #E63946; }
.thr-hero-compare { font-family: 'Inter', sans-serif; font-size: 18px; color: #999; text-decoration: line-through; }
.thr-hero-save {
  background: #E63946;
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.5px;
  padding: 4px 10px;
  border-radius: 20px;
}
.thr-hero-cta {
  display: inline-block;
  background: #E63946;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 800;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 16px 36px;
  border-radius: 10px;
  margin-bottom: 24px;
  transition: background 0.2s;
}
.thr-hero-cta:hover { background: #c92b38; }
.thr-hero-trust {
  display: flex;
  gap: 18px;
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: #777;
  font-weight: 600;
  flex-wrap: wrap;
}

@media (max-width: 768px) {
  .thr-hero { padding: 32px 18px; }
  .thr-hero-inner { grid-template-columns: 1fr; gap: 28px; }
  .thr-hero-title { font-size: 28px; }
  .thr-hero-sub { font-size: 14px; }
}
</style>

{% schema %}
{
  "name": "Thrivve Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Red Light Therapy. Hands-Free." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Just put it on and go. Lightweight, breathable, and comfortable enough to wear every day." },
    { "type": "text", "id": "price", "label": "Price", "default": "$80.00" },
    { "type": "text", "id": "compare_price", "label": "Compare-at price", "default": "$134.00" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop The Cap" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Thrivve Hero" }]
}
{% endschema %}
