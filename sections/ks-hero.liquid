.thrivve-hero {
  padding: 4rem 0;
}

.thrivve-hero__inner {
  max-width: 720px;
  text-align: center;
  margin: 0 auto;
}

.thrivve-hero__eyebrow {
  font-size: 1.3rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1.2rem;
  opacity: 0.75;
}

.thrivve-hero__heading {
  font-size: 4.2rem;
  line-height: 1.05;
  margin-bottom: 1.6rem;
}

.thrivve-hero__subheading {
  font-size: 1.8rem;
  line-height: 1.5;
  margin-bottom: 2.4rem;
  opacity: 0.85;
}

.thrivve-hero__actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.thrivve-hero__button {
  padding: 1.4rem 3.2rem;
  font-size: 1.5rem;
}

.thrivve-hero__support {
  font-size: 1.3rem;
  opacity: 0.7;
}

@media screen and (max-width: 749px) {
  .thrivve-hero__heading {
    font-size: 3rem;
  }
  .thrivve-hero__subheading {
    font-size: 1.6rem;
  }
}
