<style>
  .thrivve-hero {
    padding: 4rem 0;
  }
  .thrivve-hero__inner {
    max-width: 720px;
    text-align: center;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .thrivve-hero__eyebrow {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    opacity: 0.75;
  }
  .thrivve-hero__heading {
    font-size: 4.2rem;
    line-height: 1.05;
    margin-bottom: 1.6rem;
  }
  .thrivve-hero__heading p {
    margin: 0;
  }
  .thrivve-hero__subheading {
    font-size: 1.8rem;
    line-height: 1.5;
    margin-bottom: 2.4rem;
    opacity: 0.85;
  }
  .thrivve-hero__subheading p {
    margin: 0;
  }
  .thrivve-hero__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .thrivve-hero__button {
    padding: 1.4rem 3.2rem;
    font-size: 1.5rem;
  }
  .thrivve-hero__support {
    font-size: 1.3rem;
    opacity: 0.7;
    margin: 0;
  }
  @media screen and (max-width: 749px) {
    .thrivve-hero__heading {
      font-size: 3rem;
    }
    .thrivve-hero__subheading {
      font-size: 1.6rem;
    }
  }
</style>

<div class="thrivve-hero color-{{ section.settings.color_scheme }}">
  <div class="page-width thrivve-hero__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="thrivve-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <div class="thrivve-hero__heading">{{ section.settings.heading }}</div>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <div class="thrivve-hero__subheading">{{ section.settings.subheading }}</div>
    {% endif %}

    <div class="thrivve-hero__actions">
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="button button--primary thrivve-hero__button">
          {{ section.settings.button_label | escape }}
        </a>
      {% endif %}
      {% if section.settings.support_line != blank %}
        <p class="thrivve-hero__support">{{ section.settings.support_line | escape }}</p>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Thrivve Hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "FDA-REGISTERED RED LIGHT THERAPY"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Visibly Thicker Hair in 90 Days. Or Your Money Back.</p>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Dual-wavelength red light therapy — the same 660nm/850nm technology used in clinical hair restoration — now in a cap you wear for 15 minutes a day.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Buy It Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "support_line",
      "label": "Support line under button",
      "default": "30-Day Money-Back Guarantee · Free Shipping Over $50"
    }
  ],
  "presets": [
    {
      "name": "Thrivve Hero"
    }
  ]
}
{% endschema %}
