<style>
  .thrivve-compare {
    padding: 4rem 0;
  }
  .thrivve-compare__heading {
    text-align: center;
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .thrivve-compare__subheading {
    text-align: center;
    font-size: 1.6rem;
    opacity: 0.75;
    max-width: 560px;
    margin: 0 auto 3.2rem;
  }
  .thrivve-compare__table {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    border-collapse: collapse;
    font-size: 1.5rem;
  }
  .thrivve-compare__table th {
    font-size: 1.6rem;
    padding: 1.4rem 1.2rem;
    text-align: center;
  }
  .thrivve-compare__table th:first-child {
    text-align: left;
  }
  .thrivve-compare__table th.us {
    color: var(--thrivve-accent, #e8492a);
  }
  .thrivve-compare__table td {
    padding: 1.4rem 1.2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    text-align: center;
  }
  .thrivve-compare__table td:first-child {
    text-align: left;
    opacity: 0.85;
  }
  .thrivve-compare__check {
    color: var(--thrivve-accent, #e8492a);
    font-size: 1.8rem;
  }
  .thrivve-compare__dash {
    opacity: 0.35;
  }
  @media screen and (max-width: 600px) {
    .thrivve-compare__table {
      font-size: 1.3rem;
    }
    .thrivve-compare__table th, .thrivve-compare__table td {
      padding: 1rem 0.6rem;
    }
  }
</style>

<div class="thrivve-compare color-{{ section.settings.color_scheme }} page-width">
  {% if section.settings.heading != blank %}
    <h2 class="thrivve-compare__heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <p class="thrivve-compare__subheading">{{ section.settings.subheading }}</p>
  {% endif %}

  <table class="thrivve-compare__table">
    <thead>
      <tr>
        <th></th>
        <th class="us">{{ section.settings.us_label | default: 'Thrivve Labs' }}</th>
        <th>{{ section.settings.others_label | default: 'Others' }}</th>
      </tr>
    </thead>
    <tbody>
      {% for block in section.blocks %}
        {% if block.type == 'row' %}
          <tr {{ block.shopify_attributes }}>
            <td>{{ block.settings.feature | escape }}</td>
            <td>{% if block.settings.us_has %}<span class="thrivve-compare__check">✓</span>{% else %}<span class="thrivve-compare__dash">—</span>{% endif %}</td>
            <td>{% if block.settings.others_has %}<span class="thrivve-compare__check">✓</span>{% else %}<span class="thrivve-compare__dash">—</span>{% endif %}</td>
          </tr>
        {% endif %}
      {% endfor %}
    </tbody>
  </table>
</div>

{% schema %}
{
  "name": "Thrivve Comparison",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Thrivve Labs"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Dual-wavelength coverage and daily comfort, built for consistency."
    },
    {
      "type": "text",
      "id": "us_label",
      "label": "\"Us\" column label",
      "default": "Thrivve Labs"
    },
    {
      "type": "text",
      "id": "others_label",
      "label": "\"Others\" column label",
      "default": "Others"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Dual-wavelength (660nm + 850nm)"
        },
        {
          "type": "checkbox",
          "id": "us_has",
          "label": "Thrivve Labs has this",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "others_has",
          "label": "Others have this",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Comparison",
      "blocks": [
        {
          "type": "row",
          "settings": { "feature": "Dual-wavelength (660nm + 850nm)", "us_has": true, "others_has": false }
        },
        {
          "type": "row",
          "settings": { "feature": "Full crown + hairline coverage", "us_has": true, "others_has": false }
        },
        {
          "type": "row",
          "settings": { "feature": "Published diode count", "us_has": true, "others_has": false }
        },
        {
          "type": "row",
          "settings": { "feature": "30-day money-back guarantee", "us_has": true, "others_has": true }
        }
      ]
    }
  ]
}
{% endschema %}
