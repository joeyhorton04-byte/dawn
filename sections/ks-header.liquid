<header class="thr-header">
  <div class="thr-header-inner">
    <button class="thr-menu-toggle" onclick="thrToggleMenu()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>

    <a href="/" class="thr-logo">THRIVVE <span>LABS</span></a>

    <nav class="thr-nav">
      <a href="/">Home</a>
      <a href="/pages/track-order">Track Your Order</a>
      <a href="/pages/contact">Contact</a>
    </nav>

    <div class="thr-header-icons">
      <a href="/search" class="thr-icon" aria-label="Search">🔍</a>
      <a href="/account" class="thr-icon" aria-label="Account">👤</a>
      <a href="/cart" class="thr-icon thr-cart-icon" aria-label="Cart">
        🛒
        {% if cart.item_count > 0 %}
          <span class="thr-cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>

  <div class="thr-mobile-menu" id="thr-mobile-menu">
    <a href="/">Home</a>
    <a href="/pages/track-order">Track Your Order</a>
    <a href="/pages/contact">Contact</a>
  </div>
</header>

<style>
.thr-header {
  background: #0B0B0B;
  position: relative;
  z-index: 90;
}
.thr-header-inner {
  max-width: 1300px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 32px;
}
.thr-logo {
  font-family: 'Archivo Black', sans-serif;
  font-size: 20px;
  letter-spacing: 0.5px;
  color: #FFFFFF;
  text-decoration: none;
  text-transform: uppercase;
}
.thr-logo span { color: #E63946; }
.thr-nav {
  display: flex;
  gap: 32px;
}
.thr-nav a {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: #DDDDDD;
  text-decoration: none;
  letter-spacing: 0.3px;
}
.thr-nav a:hover { color: #E63946; }
.thr-header-icons {
  display: flex;
  align-items: center;
  gap: 18px;
}
.thr-icon {
  font-size: 16px;
  text-decoration: none;
  position: relative;
  filter: grayscale(1) brightness(2);
}
.thr-cart-icon { position: relative; }
.thr-cart-count {
  position: absolute;
  top: -8px;
  right: -10px;
  background: #E63946;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.thr-menu-toggle {
  display: none;
  flex-direction: column;
  gap: 4px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
}
.thr-menu-toggle span {
  width: 22px;
  height: 2px;
  background: #fff;
}
.thr-mobile-menu {
  display: none;
  flex-direction: column;
  background: #0B0B0B;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 12px 24px 18px;
}
.thr-mobile-menu.open { display: flex; }
.thr-mobile-menu a {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: #DDDDDD;
  text-decoration: none;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

@media (max-width: 768px) {
  .thr-header-inner { padding: 14px 18px; }
  .thr-nav { display: none; }
  .thr-menu-toggle { display: flex; }
  .thr-logo { font-size: 16px; }
}
</style>

<script>
function thrToggleMenu() {
  document.getElementById('thr-mobile-menu').classList.toggle('open');
}
</script>

{% schema %}
{
  "name": "Thrivve Header",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [{ "name": "Thrivve Header" }]
}
{% endschema %}
