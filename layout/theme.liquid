  </div>
</div>
 
<script>
  var KLAVIYO_PUBLIC_KEY = 'XkeJcu';
  var KLAVIYO_LIST_ID = 'YqbNF9';
 
  function kngdmSubmit() {
    var email = document.getElementById('kngdm-email').value;
    var phone = document.getElementById('kngdm-phone').value;
    var countryCode = document.getElementById('kngdm-flag').value;
 
    if (!email || !email.includes('@')) {
      document.getElementById('kngdm-email').style.borderColor = '#ff4444';
      return;
    }
 
    var btn = document.getElementById('kngdm-submit');
    btn.textContent = 'SENDING...';
    btn.disabled = true;
 
    var profileData = {
      type: 'profile',
      attributes: {
        email: email,
        properties: {
          source: 'KNGDM Popup - Free Expedited Shipping'
        }
      }
    };
 
    if (phone) {
      profileData.attributes.phone_number = countryCode + phone.replace(/\D/g, '');
    }
 
    fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'revision': '2024-02-15'
      },
      body: JSON.stringify({
        data: {
          type: 'subscription',
          attributes: {
            list_id: KLAVIYO_LIST_ID,
            custom_source: 'KNGDM Popup',
            profile: {
              data: {
                type: 'profile',
                attributes: {
                  email: email,
                  phone_number: phone ? (countryCode + phone.replace(/[^0-9]/g, '')) : undefined
                }
              }
            }
          }
        }
      })
    })
    .then(function(res) {
      document.getElementById('kngdm-form').style.display = 'none';
      document.getElementById('kngdm-success').classList.add('visible');
      localStorage.setItem('kngdm_popup_shown', '1');
    })
    .catch(function(err) {
      document.getElementById('kngdm-form').style.display = 'none';
      document.getElementById('kngdm-success').classList.add('visible');
      localStorage.setItem('kngdm_popup_shown', '1');
    });
  }
 
  function kngdmClose() {
    document.getElementById('kngdm-overlay').classList.remove('active');
    localStorage.setItem('kngdm_popup_shown', '1');
  }
 
  window.addEventListener('load', function() {
    if (!localStorage.getItem('kngdm_popup_shown')) {
      setTimeout(function() {
        document.getElementById('kngdm-overlay').classList.add('active');
      }, 3000);
    }
  });
</script>
